# =============================================================================
# Bartender AI Assistant — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bartender_ai
POSTGRES_USER=bartender
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://bartender:changeme@postgres:5432/bartender_ai

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Qdrant (Vector DB)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# -----------------------------------------------------------------------------
# NATS JetStream
# -----------------------------------------------------------------------------
NATS_URL=nats://nats:4222
NATS_JETSTREAM_DOMAIN=

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=bartender-ai
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Telegram Bot (for Agent Swarm human interface)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# -----------------------------------------------------------------------------
# LLM Providers (Phase 0: at least one needed for agent reasoning)
# -----------------------------------------------------------------------------
# Groq (Free tier LLM)
GROQ_API_KEY=gsk_...

# Anthropic (Paid tier LLM)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Paid tier LLM / Embeddings)
OPENAI_API_KEY=sk-...

# Ollama (Local fallback)
OLLAMA_BASE_URL=http://ollama:11434

# -----------------------------------------------------------------------------
# Stripe (Phase 2)
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://api:8000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=${CLERK_PUBLISHABLE_KEY}
CLERK_SECRET_KEY=${CLERK_SECRET_KEY}

# -----------------------------------------------------------------------------
# Agent Swarm
# -----------------------------------------------------------------------------
AGENT_HEARTBEAT_INTERVAL_SECONDS=30
AGENT_HEARTBEAT_TIMEOUT_SECONDS=90
AGENT_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_FREE_RPD=100
RATE_LIMIT_PAID_RPM=60
RATE_LIMIT_PAID_RPD=1000
